if [ -n "$BASH_VERSION" ]; then
  alias s="source ~/.bashrc"
elif [ -n "$ZSH_VERSION" ]; then
  alias s="source ~/.zshrc"
fi

alias cdf="cd /fsx/jlee; ls"
alias cdc="cd /fsx/jlee/repos/quant-research/packages/configs"
alias cdw="cd /fsx/jlee/repos/quant-research/workspace"

alias vi='vim'
alias lt='ls -lrt'
alias ll='ls -al'
alias tf='tail -f'

alias ta='tmux a'
alias tls='tmux ls'
alias tk='tmux kill-session'

alias gt='git status'
alias ga='git add'
alias gh='git checkout'
alias gw='git worktree'
alias gc='git commit -v'
alias gd='git diff'
alias gl='git log -3'
alias gll='git log -6'
alias gb='git branch'

alias py='python'
alias cmake_debug="cmake -DCMAKE_BUILD_TYPE=Debug"