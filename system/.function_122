#
# console
#

tv() {
  if tmux has-session -t my-session > /dev/null 2>&1; then
    echo tmux attaching to my-session
    tmux attach -d -t my-session

  else
    echo tmux creating my-session
    tmux new-session -d -s my-session -c "$HOME"

    # 1
    tmux rename-window -t my-session:1 htop
    tmux split-window -v -p 80 -t htop -c "/fsx/jlee/repos/quant-research"
    tmux split-window -h -t htop.2 -c "/fsx/jlee/repos/quant-research"

    tmux send-keys -t htop.1 'htop' C-m
    #tmux send-keys -t htop.2
    #tmux send-keys -t htop.3

    # 2
    tmux new-window -n code -c "/fsx/jlee/repos/execution-monorepo"
    tmux split-window -h -t code -c "/fsx/jlee/repos/execution-monorepo"
    #tmux send-keys -t code.1 'vim -c "NERDTree"' C-m
    #tmux send-keys -t code.2 'vim -c "NERDTree"' C-m

    # 3
    tmux new-window -n sim -c "/fsx/jlee/simbase"
    tmux split-window -h -t sim -c "/fsx/jlee/simbase"

    # 4
    tmux new-window -n capture -c "/fsx/jlee/fitbase"
    tmux split-window -h -t capture -c "/fsx/jlee/fitbase"

    # 5
    tmux new-window -n config -c "/fsx/jlee/repos/quant-research/packages/configs"
    tmux split-window -h -t config -c "/fsx/jlee/repos/quant-research/packages/configs"

    # 6
    tmux new-window -n s3 -c "/fsx/jlee/s3"
    tmux split-window -h -t s3

    # 7
    tmux new-window -n report -c "/fsx/jlee/scorebase/prod"
    tmux split-window -h -t report -c "/fsx/jlee/scorebase"

    #8
    tmux new-window -n staging

    #9
    tmux new-window -n nexyst

    #10
    tmux new-window -n temple-okx

    #
    tmux select-window -t code.1
    tmux select-pane -t 1
    tmux -2 attach-session -t my-session
  fi
}

tt() {
  local SDIR="/home/jlee/s3"
  local TOPDIR="/home/jlee"
  local EMDIR="$TOPDIR/repos/em/em-development"
  local QRDIR="$TOPDIR/repos/qr/qr-wsl"
  local CONFIGDIR="$TOPDIR/repos/qr/qr-wsl/packages/configs"
  local SIMWORKDIR="$TOPDIR/repos/qr/qr-wsl/workspace/sim"
  local SIMDIR="$TOPDIR/simbase"
  local FITWORKDIR="$TOPDIR/repos/qr/qr-wsl/workspace/fit"
  local FITDIR="$TOPDIR/fitbase"
  local REPWORKDIR="$TOPDIR/repos/qr/qr-wsl/workspace/report"
  local REPDIR="$TOPDIR/scorebase"
  local SESSION="my-session"
  local QRSTART="$HOME"
  local EMSTART="$HOME"
  local SIMWORKSTART="$HOME"
  local SIMSTART="$HOME"
  local FITWORKSTART="$HOME"
  local FITSTART="$HOME"
  local CONFIGSTART="$HOME"
  local AWSSTART="$HOME"
  local REPWORKSTART="$HOME"
  local REPSTART="$HOME"
  local htop_bottom_pane
  local htop_window_id

  if [ -d "$TOPDIR" ]; then
    QRSTART="$QRDIR"
    EMSTART="$EMDIR"
    SIMWORKSTART="$SIMWORKDIR"
    SIMSTART="$SIMDIR"
    FITWORKSTART="$FITWORKDIR"
    FITSTART="$FITDIR"
    CONFIGSTART="$CONFIGDIR"
    AWSSTART="$SDIR"
    REPWORKSTART="$REPWORKDIR"
    REPSTART="$REPDIR"
  fi

  if tmux has-session -t "$SESSION" > /dev/null 2>&1; then
    echo "tmux attaching to $SESSION"
    tmux attach-session -d -t "$SESSION"
    return
  fi

  echo "tmux creating $SESSION"
  htop_window_id="$(tmux new-session -d -s "$SESSION" -c "$HOME" -P -F '#{window_id}')"

  # 1
  tmux rename-window -t "$first_window_id" qr
  first_pane_id="$(tmux display-message -pt "$first_window_id" '#{pane_id}')"
  tmux send-keys -t "$first_pane_id" 'htop' C-m
  first_bottom_pane="$(tmux split-window -v -p 70 -c "$QRSTART" -t "$first_window_id" -P -F '#{pane_id}')"
  tmux split-window -h -t "$first_bottom_pane" -c "$QRSTART"

  # 2
  tmux new-window -t "$SESSION" -n em -c "$EMSTART"
  tmux split-window -h -t "$SESSION:em" -c "$EMSTART"

  # 3
  tmux new-window -t "$SESSION" -n sim -c "$SIMWORKSTART"
  tmux split-window -h -t "$SESSION:sim" -c "$SIMSTART"

  # 4
  tmux new-window -t "$SESSION" -n fit -c "$FITWORKSTART"
  tmux split-window -h -t "$SESSION:fit" -c "$FITSTART"

  # 5
  tmux new-window -t "$SESSION" -n config -c "$CONFIGSTART"
  tmux split-window -h -t "$SESSION:config" -c "$CONFIGSTART"

  # 6
  tmux new-window -t "$SESSION" -n aws -c "$AWSSTART"
  tmux split-window -h -t "$SESSION:aws" -c "$AWSSTART"

  # 7
  tmux new-window -t "$SESSION" -n report -c "$REPWORKSTART"
  tmux split-window -h -t "$SESSION:report" -c "$REPSTART"

  # 8
  tmux new-window -t "$SESSION" -n doc -c "$HOME/doc"

  # 9
  tmux new-window -t "$SESSION" -n nexyst

  #10

  tmux select-window -t "$first_window_id"
  tmux select-pane -t "$first_bottom_pane"
  tmux attach-session -t "$SESSION"
}

gwa() {
  echo git worktree add -b new-branch-name ../directory-name source-branch
}

